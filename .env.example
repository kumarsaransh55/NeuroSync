# NeuroSync frontend environment variables.
# Copy this file to ".env" (or ".env.local") to override the defaults.

# Base URL of the NeuroSync API.
# If unset, the app uses the deployed Azure API below.
VITE_API_BASE=https://neurosync.azurewebsites.net/api

# To run against a backend on your own machine instead, comment out the line
# above and point this at your local backend's URL + /api, for example:
# VITE_API_BASE=http://localhost:5219/api

# --- Outlook / Microsoft Graph integration (optional) ---
# Provide these to enable REAL Outlook email (see docs/OUTLOOK-INTEGRATION.md).
# Without them, the inbox shows representative demo emails.
# VITE_MS_CLIENT_ID=00000000-0000-0000-0000-000000000000
# VITE_MS_TENANT=organizations
